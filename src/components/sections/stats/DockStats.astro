---
import ItemStats from './ItemStats.astro';

import CarpenterIcon from '../../icons/stats/CarpenterIcon.astro';
import ClientsIcon from '../../icons/stats/ClientsIcon.astro';
import WoodIcon from '../../icons/stats/WoodIcon.astro';
import WarrantyIcon from '../../icons/stats/WarrantyIcon.astro';
---

<div class="w-full">
  <div class="w-full grid grid-cols-2 gap-5 md:grid-cols-4 md:gap-0 place-items-center">
    <ItemStats
      title="Años de experiencia"
      value="+25"
      unit="años"
      description="Más de 25 años fabricando muebles a medida con terminaciones prolijas y duraderas."
      icon={CarpenterIcon}
    />

    <ItemStats
      title="Clientes"
      value="+200"
      unit=""
      description="Más de 200 clientes satisfechos. Atención cercana antes, durante y después de la entrega."
      icon={ClientsIcon}
    />

    <ItemStats
      title="Tipos de material"
      value="Melamina"
      unit=""
      description="Trabajamos con distintos materiales y colores para adaptarlo a tu espacio."
      icon={WoodIcon}
    />

    <ItemStats
      title="Garantía"
      value="Cambio"
      unit=""
      description="Si el producto llega dañado, lo reemplazamos o resolvemos el problema sin vueltas."
      icon={WarrantyIcon}
    />
  </div>
</div>
