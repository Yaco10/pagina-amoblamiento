---
import Container from '../../ui/Container.astro';
---

<section
  class="relative min-h-[100dvh] lg:min-h-screen w-full overflow-hidden flex items-center justify-center"
>
  <img
    src="/images/hero2.jpg"
    alt="Amoblamientos modernos"
    class="absolute inset-0 h-full w-full object-cover"
  />

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/40"></div>

  <Container>
    <div class="relative flex items-center justify-center pb-10">
      <div class="flex max-w-6xl flex-col items-center text-center">
        <p class="text-[16px] sm:text-[24px] font-medium uppercase tracking-[0.35em] text-white/80">
          Amoblamientos
        </p>

        <h1 class="mt-4 w-full text-hero">Dise&ntilde;o funcional para tu hogar</h1>
        <div class="w-full sm:max-w-md lg:max-w-lg">
          <p class="mt-5 text-white/85">
            Modelos ya dise&ntilde;ados, disponibles en distintos colores y combinaciones, listos para
            acompa&ntilde;ar tu espacio.
          </p>
        </div>

        <a
          href="/#productos"
          class="btn-ui-hero mt-6 sm:inline-flex"
        >
          Ver productos
        </a>
      </div>
    </div>
  </Container>
</section>
