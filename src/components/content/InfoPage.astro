---
import Container from '../ui/Container.astro';

type InfoSection = {
  id?: string;
  title: string;
  paragraphs?: string[];
  bullets?: string[];
};

type Props = {
  eyebrow?: string;
  title: string;
  intro: string;
  updatedAt?: string;
  sections: InfoSection[];
};

const {
  eyebrow = 'Informacion',
  title,
  intro,
  updatedAt,
  sections,
} = Astro.props as Props;
---

<section class="relative overflow-hidden bg-[color:var(--color-brand-base)] py-14 pb-20 sm:py-20 sm:pb-24">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(180,131,61,0.12),transparent_42%)]"></div>
  <Container>
    <div class="mx-auto max-w-4xl">
      <div class="rounded-[32px] border border-[color:var(--color-brand-wood)]/10 bg-[color:var(--color-brand-base)]/72 p-8 shadow-[0_18px_50px_rgba(64,53,40,0.08)] backdrop-blur sm:p-10">
        <p class="text-xs font-semibold uppercase tracking-[0.36em] text-[color:var(--color-brand-accent)]">
          {eyebrow}
        </p>
        <h1 class="mt-4 text-4xl text-[color:var(--color-brand-wood)] sm:text-5xl">{title}</h1>
        <p class="mt-5 max-w-2xl text-base leading-8 text-[color:var(--color-brand-earth)]/85">
          {intro}
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-4 text-sm text-[color:var(--color-brand-earth)]/65">
          <a
            href="/#contacto"
            class="inline-flex rounded-full border border-[color:var(--color-brand-wood)]/12 bg-[color:var(--color-brand-wood)] px-5 py-2 font-semibold uppercase tracking-[0.22em] text-[color:var(--color-brand-base)] transition hover:bg-[color:var(--color-brand-earth)]"
          >
            Hacer una consulta
          </a>
          {updatedAt && <span>Ultima actualizacion: {updatedAt}</span>}
        </div>
      </div>

      <div class="mt-8 space-y-5">
        {sections.map((section) => (
          <article
            id={section.id}
            class="rounded-[28px] border border-[color:var(--color-brand-wood)]/10 bg-[color:var(--color-brand-surface)]/44 p-7 shadow-[0_10px_32px_rgba(64,53,40,0.06)]"
          >
            <h2 class="text-2xl text-[color:var(--color-brand-wood)]">{section.title}</h2>

            {section.paragraphs && (
              <div class="mt-4 space-y-4">
                {section.paragraphs.map((paragraph) => (
                  <p class="leading-8 text-[color:var(--color-brand-earth)]/85">{paragraph}</p>
                ))}
              </div>
            )}

            {section.bullets && (
              <ul class="mt-4 space-y-3 pl-5 text-[color:var(--color-brand-earth)]/85">
                {section.bullets.map((bullet) => (
                  <li class="list-disc leading-7">{bullet}</li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </div>
    </div>
  </Container>
</section>
