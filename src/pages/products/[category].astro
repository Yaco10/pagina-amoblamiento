---
import Container from '../../components/ui/Container.astro';
import ProductsPage from '../../components/products/ProductsPage';
import BaseLayout from '../../layouts/BaseLayout.astro';

const { category } = Astro.params;
const categoryLabel = (category ?? 'all').toLowerCase();
---

<BaseLayout>
  <main class="pb-12 sm:pb-16">
    <header class="w-full bg-[color:var(--color-brand-surface)]/72 p-4 px-8">
      <p class="text-sm text-[color:var(--color-brand-coyote)]/90">
        Productos /
        <span class="ml-1 font-semibold text-[color:var(--color-brand-wood)]">
          {categoryLabel === 'all' ? 'Todas' : category}
        </span>
      </p>
      <h1 class="mt-0 text-3xl font-semibold tracking-tight text-[color:var(--color-brand-earth)]">
        {categoryLabel === 'all' ? 'Todos los productos' : `Muebles de ${category}`}
      </h1>
    </header>
    <Container>
      <ProductsPage client:load category={category} />
    </Container>
  </main>
</BaseLayout>
